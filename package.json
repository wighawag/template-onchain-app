{
  "name": "template-onchain-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "cross-var": "^1.1.0",
    "husky": "^9.1.7",
    "ldenv": "^0.5.0",
    "zellij-launcher": "^0.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "utf-8-validate": "-"
    }
  },
  "scripts": {
    "prepare": "husky",
    "preinstall": "npx only-allow pnpm",
    "cleandep": "rm -rf node_modules && pnpm -r exec rm -rf node_modules",
    "---------------------- FORMAT ----------------------": "",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "---------------------- contracts ----------------------": "compile and deploy smart contracts",
    "contracts:node:local": "pnpm run --filter ./contracts node:local",
    "contracts:node:purgatory": "pnpm run --filter ./contracts node:purgatory",
    "contracts:faucet": "pnpm run --filter ./contracts faucet",
    "contracts:deploy": "pnpm run --filter ./contracts deploy",
    "contracts:deploy:watch": "pnpm run --filter ./contracts deploy:watch",
    "contracts:fork:deploy": "pnpm run --filter ./contracts fork:deploy",
    "contracts:test": "pnpm run --filter ./contracts test",
    "contracts:lint": "pnpm --filter ./contracts lint",
    "contracts:execute": "pnpm run --filter ./contracts execute",
    "contracts:fork:execute": "pnpm run --filter ./contracts fork:execute",
    "contracts:verify": "pnpm run --filter ./contracts verify",
    "contracts:compile": "pnpm --filter ./contracts compile",
    "contracts:compile:watch": "pnpm --filter ./contracts compile:watch",
    "contracts:build:watch": "pnpm --filter ./contracts typescript:watch",
    "contracts:build": "ldenv pnpm --filter ./contracts compile ~~ pnpm --filter ./contracts typescript ~~ pnpm --filter ./contracts export @@MODE --ts ../web/src/lib/deployments.ts ~~ @@",
    "contracts:export": "pnpm --filter ./contracts export",
    "---------------------- WEB ----------------------": "",
    "web:dev": "pnpm --filter ./web dev",
    "web:build": "pnpm --filter ./web build",
    "web:serve": "pnpm --filter ./web serve",
    "web:check": "pnpm --filter ./web check",
    "web:check:watch": "pnpm --filter ./web check:watch",
    "---------------------- DEPLOY ----------------------": "",
    "test": "pnpm contracts:test",
    "build": "ldenv --git -d localhost pnpm contracts:build @@MODE ~~ pnpm web:build @@MODE ~~ @@",
    "serve": "pnpm run --filter ./web serve",
    "---------------------- WEB USING EXISTING DEPLOYMENT ----------------------": "",
    "zellij-attach": "zellij-launcher a $npm_package_name-attach-$MODE || zellij -n dev/zellij-attach.kdl -s $npm_package_name-attach-$MODE",
    "attach": "ldenv -d localhost pnpm contracts:export @@MODE --ts ../web/src/lib/deployments.ts ~~ pnpm run zellij-attach ~~ @@",
    "---------------------- FULL AGAINST AN EXISTING NETWORK WITH LOCAL SERVICES ----------------------": "",
    "zellij-remote-chain": "zellij-launcher a $npm_package_name-remote-chain-$MODE || zellij -n dev/zellij-remote-chain.kdl -s $npm_package_name-remote-chain-$MODE",
    "remote-chain": "ldenv -d localhost pnpm run zellij-remote-chain @@",
    "---------------------- RUN FULL LOCAL SETUP ----------------------": "",
    "zellij": "cross-var zellij-launcher a $npm_package_name || cross-var zellij -n dev/zellij.kdl -s $npm_package_name",
    "stop": "cross-var zellij kill-session $npm_package_name",
    "start": "pnpm zellij"
  }
}
