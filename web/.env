PUBLIC_NODE_URL=
PUBLIC_CHAIN_INFO_NODE_URL=
PUBLIC_ENS_NODE_URL="https://cloudflare-eth.com"
PUBLIC_EXPLORER_BLOCK_INDEX_ENABLED=
PUBLIC_USE_INTERNAL_EXPLORER=true
PUBLIC_FAUCET_LINK=
PUBLIC_FAUCET_API=
PUBLIC_USE_BURNER_WALLET=
# Hosted sign-in service URL. When set, the connection targets 'SignedIn'
# (enabling email/social login and a local signer). When empty, the connection
# targets 'WalletConnected' (wallet-only auth). See core/connection/mode.ts.
PUBLIC_WALLET_HOST=
# How transactions are executed: 'wallet' (send from the connected wallet
# account, the default) or 'signer' (send from the local signer). 'signer'
# requires PUBLIC_WALLET_HOST to be set. See core/connection/mode.ts.
PUBLIC_EXECUTION_MODE=
# Number of days to retain operations (even if not complete) before deletion (default: 7)
PUBLIC_OPERATION_RETENTION_DAYS=
# Set to true to register the service worker in dev mode (default: off, so HMR
# is not intercepted by the SW cache). Useful for developing the SW itself.
PUBLIC_ENABLE_SW_IN_DEV=
